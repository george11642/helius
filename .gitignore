/comnode_modules/
dist/
dev-dist/
.DS_Store
*.log
.env
.env.*

# Large runtime-fetched binaries — reproduced by scripts/, streamed from CDN/R2 at runtime.
# Kept out of git so the repo stays clone-fast; see README for the asset pipeline.
public/data/**/*.pmtiles
public/models/
*.onnx
*.onnx_data
*.task
*.litertlm
*.traineddata
*.traineddata.gz

# iOS: build artifacts + the vendored LiteRT-LM binary frameworks (77MB+ each
# slice — fetched by ios/Packages/LiteRTLM/README or SPM; sources are tracked)
ios/**/.build/
ios/**/DerivedData/
ios/Packages/LiteRTLM/Frameworks/

# Xcode / SwiftPM generated user state
ios/**/xcuserdata/
ios/**/.swiftpm/
